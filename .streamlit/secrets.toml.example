# Copy to .streamlit/secrets.toml for local live-mode testing.
# On Streamlit Community Cloud, set these in the app's Settings > Secrets
# instead of committing a real secrets.toml.
#
# Leave both unset (or omit this file entirely) to ship a replay-only public
# deployment that needs no API key and cannot spend your Gemini credit.

GOOGLE_API_KEY = "your_gemini_api_key_here"
APP_PASSWORD = "choose_a_password_for_live_mode"
